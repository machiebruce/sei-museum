---
import Layout from "../../layouts/Main-Layout.astro";
import Menu from "../../components/Menu.astro";
import Card from "../../components/Card.astro";

const objects = await Astro.glob("../../pages/en/objects/*.mdx");
---

<Layout title='Saline Ettore Infersa'>
  <main class='flex flex-row'>
    <Menu HasSectionNumber={false} title='Museum objects' />
    <div class='snap-x flex-1 flex items-center justify-start gap-16 overflow-x-scroll scroll-pr-72 no-scrollbar ml-16'>
      {
        objects.map((object, i) => (
          <div class='first:ml-16 object-card'>
            <Card sectionNumber={object.frontmatter.sectionNumber} title={object.frontmatter.title} href={object.frontmatter.link} image={object.frontmatter.image} HasTools={object.frontmatter.HasTools} />
          </div>
        ))
      }

      <div class='min-w-32'>a</div>
    </div>
  </main>
</Layout>

<script>
  import { animate, stagger } from 'animejs';
  document.addEventListener("astro:page-load", () => {
    const cards: HTMLElement[] = Array.from(document.querySelectorAll(".object-card"));
    cards.forEach(c => { c.style.opacity = '0'; c.style.transform = 'translateX(40px)'; });
    animate(cards, { opacity: [0, 1], translateX: [40, 0], duration: 800, delay: stagger(120, { start: 400 }), easing: 'easeOutExpo' });
  });
</script>
