---
import Layout from "../../layouts/Main-Layout.astro";
import Menu from "../../components/Menu.astro";

const objects = await Astro.glob("../../pages/en/species/*.mdx");

interface SpeciesData {
  title: string;
  scientificName: string;
  order: string;
  image: string;
  link: string;
  sectionNumber: string;
  IsFauna: boolean;
}

const speciesByOrder = new Map<string, SpeciesData[]>();

objects.forEach((obj) => {
  if (obj.frontmatter.order) {
    const order = obj.frontmatter.order;
    if (!speciesByOrder.has(order)) speciesByOrder.set(order, []);
    speciesByOrder.get(order)!.push({
      title: obj.frontmatter.title,
      scientificName: obj.frontmatter.scientificName,
      order: obj.frontmatter.order,
      image: obj.frontmatter.image,
      link: obj.frontmatter.link,
      sectionNumber: obj.frontmatter.sectionNumber,
      IsFauna: obj.frontmatter.IsFauna,
    });
  }
});

const sortedOrders = Array.from(speciesByOrder.entries()).sort((a, b) => b[1].length - a[1].length);
const speciesJson = JSON.stringify(Object.fromEntries(speciesByOrder));
const ordersJson = JSON.stringify(sortedOrders.map(([order]) => order));
const totalSpecies = objects.length;
const totalOrders = speciesByOrder.size;
---

<style>
  .view-toggle-btn {
    transition: all 0.3s ease;
  }
  .order-btn {
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    cursor: pointer;
    flex-shrink: 0;
  }
  .order-btn:hover {
    transform: scale(1.05);
  }
  .order-btn.active {
    background: rgb(231 121 104);
    border-color: rgb(231 121 104);
    color: black;
    transform: scale(1.08);
  }
  .species-thumb {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(255, 255, 255, 0.2);
    flex-shrink: 0;
  }
</style>

<Layout title='Saline Ettore Infersa - Map'>
  <main class='flex flex-row h-screen overflow-hidden bg-gradient-to-b from-neutral-900 to-neutral-800'>
    <Menu HasSectionNumber={false} title='Salt pan species' />

    <div class='flex flex-col flex-1 overflow-hidden relative'>
      <div class='absolute top-6 left-6 z-50 flex items-center gap-4'>
        <a href={`./species`} class='view-toggle-btn flex items-center gap-2 px-6 py-3 bg-neutral-800 text-white rounded-xl hover:bg-neutral-700 no-underline border border-white/20'>
          <img src='../icons/view_column.svg' alt='view_column' class='w-6 h-6 invert' />
        </a>
        <a href={`./species-map`} class='active view-toggle-btn border border-white flex items-center gap-2 px-6 py-3 bg-neutral-800 text-white rounded-xl hover:bg-neutral-700 no-underline'>
          <img src='../icons/image_search.svg' alt='image_search' class='w-6 h-6 invert' />
        </a>
      </div>

      <div class='flex-1 flex flex-col overflow-hidden'>

        <div class='flex-1 flex flex-col items-center justify-center gap-8 p-8' id='species-area'>
          <p class='text-white/30 text-sm uppercase tracking-widest' id='order-label'>Select an order</p>
          <div class='flex gap-8 overflow-x-auto pb-4 no-scrollbar self-start' id='species-row'></div>
        </div>

        <div class='px-8 pb-8'>
          <div class='flex flex-wrap items-center gap-3 justify-center' id='orders-bar'></div>
        </div>

      </div>
    </div>
  </main>
</Layout>

<div id='map-data' data-species={speciesJson} data-orders={ordersJson} style='display:none'></div>

<script>
  import { animate, stagger } from 'animejs';

  document.addEventListener("DOMContentLoaded", () => {
    const dataEl = document.getElementById('map-data');
    const speciesData = JSON.parse(dataEl.dataset.species);
    const ordersList = JSON.parse(dataEl.dataset.orders);

    const ordersBar = document.getElementById('orders-bar');
    const speciesRow = document.getElementById('species-row');
    const orderLabel = document.getElementById('order-label');
    let activeOrder = null;

    function renderSpecies(order) {
      speciesRow.innerHTML = '';
      if (!order || !speciesData[order]) return;

      const species = speciesData[order];
      species.forEach((specie, i) => {
        const div = document.createElement('div');
        div.className = 'flex flex-col items-center gap-4 flex-shrink-0 w-[200px]';
        div.innerHTML = `
          <a href="${specie.link}" class="no-underline group flex flex-col items-center gap-3">
            <div class="w-[160px] h-[160px] rounded-2xl overflow-hidden border border-white/10 group-hover:border-primary-500 transition-all duration-300 group-hover:scale-105">
              <img src="${specie.image}" alt="${specie.title}" class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="flex items-center gap-3">
              <img src="${specie.image}" alt="" class="species-thumb w-10 h-10" />
              <span class="text-white font-bold text-sm text-center">${specie.title}</span>
            </div>
            <span class="text-white/40 text-xs italic">${specie.scientificName || ''}</span>
          </a>
        `;
        div.style.opacity = '0';
        speciesRow.appendChild(div);
      });

      requestAnimationFrame(() => {
        const cards = speciesRow.querySelectorAll(':scope > div');
        animate(cards, { opacity: [0, 1], translateY: [20, 0], duration: 500, delay: stagger(80), easing: 'easeOutExpo' });
      });
    }

    function renderOrders() {
      ordersBar.innerHTML = '';
      ordersList.forEach((order, i) => {
        const species = speciesData[order] || [];
        const btn = document.createElement('button');
        btn.className = 'order-btn flex items-center gap-3 h-14 px-5 bg-white/10 border border-white/20 rounded-full text-white font-semibold text-sm uppercase tracking-wider';
        btn.innerHTML = `
          <span class="flex items-center justify-center w-8 h-8 rounded-full bg-white/10 text-white text-xs font-bold">${species.length}</span>
          <span>${order}</span>
        `;

        btn.addEventListener('click', () => {
          document.querySelectorAll('.order-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          activeOrder = order;
          orderLabel.textContent = order;
          renderSpecies(order);
        });

        btn.style.opacity = '0';
        ordersBar.appendChild(btn);
      });

      requestAnimationFrame(() => {
        const btns = ordersBar.querySelectorAll('.order-btn');
        animate(btns, { opacity: [0, 1], scale: [0.8, 1], duration: 400, delay: stagger(50), easing: 'easeOutExpo' });
      });
    }

    renderOrders();
  });
</script>
