---
import Layout from "../layouts/Main-Layout.astro";
import CardHome from "../components/CardHome.astro";

// Recuperiamo il baseUrl per i link
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");

// URL locale dello stream HLS generato da VLC (rtsp -> HLS) sullo stesso computer dell'app.
// PLACEHOLDER: sostituire con l'indirizzo reale una volta avviato VLC (vedi memoria "live-camera-vlc-hls").
const liveStreamUrl = "http://localhost:8080/live/stream.m3u8";

const categories = [
  {
    title: "Gli Oggetti del Museo",
    href: `./objects`,
    image: `./bg-oggetti.png`,
    subtitle: "La Storia",
    sectionNumber: "01",
    description: "Strumenti autentici che raccontano secoli di tradizione salinara e il mestiere antico della raccolta del sale.",
    HasDescription: true,
  },
  {
    title: "Le Specie delle Saline",
    href: `./species`,
    image: `./bg-specie.jpg`,
    subtitle: "La Fauna",
    sectionNumber: "02",
    description: "Un ecosistema unico dove convivono fenicotteri, aironi e una ricca vegetazione adattata all'acqua salata.",
    HasDescription: true,
  },
  {
    title: "Nidificazioni dal vivo",
    href: `./live`,
    image: `./bg-live.jpg`,
    subtitle: "Camera live",
    sectionNumber: "03",
    description: "Un ecosistema unico dove convivono fenicotteri, aironi e una ricca vegetazione adattata all'acqua salata.",
    HasDescription: true,
  },
];
---

<Layout title='Live Stream | SEI Museum'>
  <main class='flex overflow-hidden flex-col justify-center items-center p-8 w-full h-screen bg-neutral-900'>
    <div class='flex flex-col items-center mb-8'>
      <a href={`./`}>
        <img src={`./sei_logo.svg`} alt='Logo SEI Museum' class='mb-4 w-32 h-auto' />
      </a>
      <h1 class='mb-2 text-4xl font-bold text-white'>Nidificazioni dal vivo</h1>
      <p class='text-xl text-white/60'>Live streaming dalle Saline Ettore Infersa</p>
    </div>

    <!-- Container video responsive -->
    <div class='overflow-hidden w-full max-w-6xl rounded-2xl border shadow-2xl aspect-video border-white/10 bg-black'>
      <video id='live-video' class='w-full h-full' controls autoplay muted playsinline data-src={liveStreamUrl}></video>
    </div>

    <!-- Pulsante torna indietro -->

    <a href={`./`}
    class='px-8 py-4 mt-8 font-bold text-black bg-white rounded-full transition-all duration-300 hover:bg-white/90 hover:-translate-y-1' > Torna alla Home </a>
  </main>
</Layout>

<style>
  .transition-all {
    transition-property: all;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 500ms;
  }
</style>

<script>
  import Hls from "hls.js";

  function initLivePlayer() {
    const video = document.getElementById("live-video") as HTMLVideoElement | null;
    if (!video) return;
    const src = video.dataset.src;
    if (!src) return;

    if (video.canPlayType("application/vnd.apple.mpegurl")) {
      video.src = src;
    } else if (Hls.isSupported()) {
      const hls = new Hls();
      hls.loadSource(src);
      hls.attachMedia(video);
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("astro:page-load", initLivePlayer);
  } else {
    initLivePlayer();
  }
</script>
