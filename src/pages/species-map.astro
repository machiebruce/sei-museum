---
import Layout from "../layouts/Main-Layout.astro";
import Menu from "../components/Menu.astro";

const objects = await Astro.glob("../pages/species/*.mdx");

interface SpeciesData {
  title: string;
  scientificName: string;
  order: string;
  image: string;
  link: string;
  sectionNumber: string;
  IsFauna: boolean;
}

const speciesByOrder = new Map<string, SpeciesData[]>();

objects.forEach((obj) => {
  if (obj.frontmatter.order) {
    const order = obj.frontmatter.order;
    if (!speciesByOrder.has(order)) speciesByOrder.set(order, []);
    speciesByOrder.get(order)!.push({
      title: obj.frontmatter.title,
      scientificName: obj.frontmatter.scientificName,
      order: obj.frontmatter.order,
      image: obj.frontmatter.image,
      link: obj.frontmatter.link,
      sectionNumber: obj.frontmatter.sectionNumber,
      IsFauna: obj.frontmatter.IsFauna,
    });
  }
});

const sortedOrders = Array.from(speciesByOrder.entries()).sort((a, b) => b[1].length - a[1].length);
const speciesJson = JSON.stringify(Object.fromEntries(speciesByOrder));
const ordersJson = JSON.stringify(sortedOrders.map(([order]) => order));
const totalSpecies = objects.length;
const totalOrders = speciesByOrder.size;
---

<style>
  .order-pill { transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); }
  .order-pill:hover { transform: scale(1.06); }
  .order-pill.active { background: rgb(231 121 104); border-color: rgb(231 121 104); color: black; transform: scale(1.08); }
  .flow-line { width: 2px; height: 40px; background: linear-gradient(to bottom, rgba(231, 121, 104, 0.5), rgba(231, 121, 104, 0.1)); flex-shrink: 0; }
  .species-card { transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); }
  .species-card:hover { transform: scale(1.05); }
  .species-card:hover .species-circle { border-color: rgb(231 121 104 / 0.8); }
  .species-circle { transition: all 0.3s ease; }
</style>

<Layout title='Saline Ettore Infersa - Mappa'>
  <main class='flex flex-row h-screen overflow-hidden bg-gradient-to-b from-neutral-900 to-neutral-800'>
    <Menu HasSectionNumber={false} title='' />

    <div class='flex flex-col flex-1 overflow-hidden relative'>
      <div class='absolute top-6 left-6 z-50 flex items-center gap-4'>
        <a href={`./species`} class='flex items-center gap-2 px-6 py-3 bg-neutral-800 text-white rounded-xl hover:bg-neutral-700 no-underline border border-white/20 transition-all duration-300'>
          <img src='./icons/view_column.svg' alt='view_column' class='w-6 h-6 invert' />
        </a>
        <a href={`./species-map`} class='border border-white flex items-center gap-2 px-6 py-3 bg-neutral-800 text-white rounded-xl hover:bg-neutral-700 no-underline transition-all duration-300'>
          <img src='./icons/image_search.svg' alt='image_search' class='w-6 h-6 invert' />
        </a>
      </div>

      <div class='flex-1 flex flex-col overflow-hidden relative'>

        <div id='orders-view' class='absolute inset-0 flex flex-col items-center justify-center p-8'>
          <h1 class='text-white/20 text-sm uppercase tracking-widest mb-8 font-semibold'>Le specie delle saline</h1>
          <div id='orders-grid' class='flex flex-wrap justify-center gap-4 max-w-3xl'></div>
        </div>

        <div id='species-view' class='absolute inset-0 flex flex-col items-center overflow-y-auto p-8 opacity-0 pointer-events-none'>
          <div class='flex flex-col items-center gap-0 mb-8'>
            <div class='flex items-center gap-4 mb-2'>
              <button id='back-btn' class='order-pill flex items-center justify-center w-12 h-12 rounded-full bg-white/10 border border-white/10 text-white'>
                <svg width='18' height='18' viewBox='0 0 16 16' fill='none'><path d='M10 12L6 8L10 4' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/></svg>
              </button>
              <div id='selected-pill' class='order-pill flex items-center gap-3 h-12 px-5 bg-primary-500 rounded-full text-black font-bold text-sm uppercase tracking-wider'></div>
            </div>
            <div class='flow-line'></div>
            <div class='w-3 h-3 rounded-full bg-primary-500/40'></div>
          </div>

          <div id='species-grid' class='flex flex-wrap justify-center gap-6 max-w-5xl'></div>
        </div>

      </div>
    </div>
  </main>
</Layout>

<div id='map-data' data-species={speciesJson} data-orders={ordersJson} style='display:none'></div>

<script>
  import { animate, stagger } from 'animejs';

  document.addEventListener("astro:page-load", () => {
    const dataEl = document.getElementById('map-data');
    const speciesData = JSON.parse(dataEl.dataset.species);
    const ordersList = JSON.parse(dataEl.dataset.orders);

    const ordersGrid = document.getElementById('orders-grid');
    const ordersView = document.getElementById('orders-view');
    const speciesView = document.getElementById('species-view');
    const speciesGrid = document.getElementById('species-grid');
    const selectedPill = document.getElementById('selected-pill');
    const backBtn = document.getElementById('back-btn');

    function showOrdersView() {
      animate(speciesView, { opacity: [1, 0], duration: 200, easing: 'easeOutExpo', begin: () => speciesView.classList.add('pointer-events-none') });
      animate(ordersView, { opacity: [0, 1], duration: 400, delay: 200, easing: 'easeOutExpo', begin: () => ordersView.classList.remove('pointer-events-none') });
    }

    function showSpeciesView(order) {
      const species = speciesData[order];
      if (!species) return;

      selectedPill.innerHTML = `<span class="flex items-center justify-center w-7 h-7 rounded-full bg-black/20 text-black text-xs font-bold">${species.length}</span><span>${order}</span>`;

      speciesGrid.innerHTML = '';
      species.forEach((specie) => {
        const a = document.createElement('a');
        a.href = specie.link;
        a.className = 'species-card no-underline flex flex-col items-center gap-3 w-[140px] p-4 rounded-2xl bg-white/5 border border-white/5 hover:bg-white/10';
        a.innerHTML = `
          <div class='species-circle w-24 h-24 rounded-full overflow-hidden border-2 border-white/20 flex-shrink-0'>
            <img src="${specie.image}" alt="${specie.title}" class='w-full h-full object-cover' loading='lazy' />
          </div>
          <span class="text-white text-xs font-bold text-center leading-tight">${specie.title}</span>
          <span class="text-white/30 text-xs italic text-center">${specie.scientificName || ''}</span>
        `;
        a.style.opacity = '0';
        a.style.transform = 'translateY(15px)';
        speciesGrid.appendChild(a);
      });

      animate(ordersView, { opacity: [1, 0], duration: 200, easing: 'easeOutExpo', begin: () => ordersView.classList.add('pointer-events-none') });

      setTimeout(() => {
        speciesView.classList.remove('pointer-events-none');
        animate(speciesView, { opacity: [0, 1], duration: 400, easing: 'easeOutExpo' });
        animate(speciesGrid.querySelectorAll(':scope > a'), { opacity: [0, 1], translateY: [15, 0], duration: 500, delay: stagger(60), easing: 'easeOutExpo' });
      }, 250);
    }

    function renderOrders() {
      ordersGrid.innerHTML = '';
      ordersList.forEach((order, i) => {
        const species = speciesData[order] || [];
        const btn = document.createElement('button');
        btn.className = 'order-pill flex items-center gap-3 h-12 px-5 bg-white/10 border border-white/10 rounded-full text-white font-semibold text-sm uppercase tracking-wider';
        btn.innerHTML = `<span class="flex items-center justify-center w-7 h-7 rounded-full bg-white/10 text-white text-xs font-bold">${species.length}</span><span>${order}</span>`;
        btn.addEventListener('click', () => showSpeciesView(order));
        btn.style.opacity = '0';
        ordersGrid.appendChild(btn);
      });

      requestAnimationFrame(() => {
        animate(ordersGrid.querySelectorAll('.order-pill'), { opacity: [0, 1], scale: [0.8, 1], duration: 500, delay: stagger(40), easing: 'easeOutExpo' });
      });
    }

    backBtn.addEventListener('click', showOrdersView);
    renderOrders();
  });
</script>
