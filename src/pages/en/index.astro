---
import Layout from "../../layouts/Main-Layout.astro";
import CardHome from "../../components/CardHome.astro";

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");

const categories = [
  {
    title: "Museum Objects",
    href: `./objects`,
    image: `../bg-oggetti.png`,
    subtitle: "History",
    sectionNumber: "01",
    description: "Authentic tools that tell centuries of salt pan tradition and the ancient craft of salt harvesting.",
    HasDescription: true,
  },
  {
    title: "Salt Pan Species",
    href: `./species`,
    image: `../bg-specie.jpg`,
    subtitle: "Fauna",
    sectionNumber: "02",
    description: "A unique ecosystem where flamingos, herons, and rich vegetation adapted to salt water coexist.",
    HasDescription: true,
  },
  {
    title: "Live Nesting",
    image: `../bg-live.jpg`,
    subtitle: "Live camera",
    sectionNumber: "03",
    description: "Watch live nesting in the salt pans through our cameras.",
    HasDescription: true,
  },
];
---

<Layout title='Home | SEI Museum'>
  <main class='flex overflow-hidden flex-col justify-between items-center py-16 w-full h-screen bg-neutral-900'>
    <div class='flex flex-col items-center home-logo'>
      <img src={`../sei_logo.svg`} alt='SEI Museum Logo' class='w-32 h-auto' />
    </div>

    <div class='flex flex-row gap-12 items-stretch mx-auto'>
      {
        categories.map((cat) => (
          <div class='home-card'>
            <CardHome sectionNumber={cat.sectionNumber} title={cat.title} description={cat.description} HasDescription={cat.HasDescription} href={cat.href} image={cat.image} />
          </div>
        ))
      }
    </div>

    <a href={`./credits`} class='home-credits px-8 py-4 text-lg font-bold tracking-wide text-black uppercase bg-white rounded-full transition-all duration-300 hover:bg-white/90 hover:-translate-y-1 hover:shadow-2xl'> Credits </a>
  </main>

  <script>
    import { animateHomepage } from "../../scripts/animations.js";
    document.addEventListener("DOMContentLoaded", animateHomepage);
  </script>
</Layout>

<style>
  .transition-all {
    transition-property: all;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 500ms;
  }
</style>
