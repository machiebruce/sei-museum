---
import Layout from "../../layouts/Main-Layout.astro";

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
const youtubeLiveId = "jfKfPfyJRdk";
---

<Layout title='Live Stream | SEI Museum'>
  <main class='flex overflow-hidden flex-col justify-center items-center p-8 w-full h-screen bg-neutral-900'>
    <div class='flex flex-col items-center mb-8'>
      <a href={`/en`}>
        <img src={`../sei_logo.svg`} alt='SEI Museum Logo' class='mb-4 w-32 h-auto' />
      </a>
      <h1 class='mb-2 text-4xl font-bold text-white'>Live Nesting</h1>
      <p class='text-xl text-white/60'>Live streaming from Saline Ettore Infersa</p>
    </div>

    <div class='overflow-hidden w-full max-w-6xl rounded-2xl border shadow-2xl aspect-video border-white/10'>
      <iframe class='w-full h-full' src={`https://www.youtube.com/embed/${youtubeLiveId}?autoplay=1&mute=0`} title='YouTube Live Stream' frameborder='0' allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share' allowfullscreen></iframe>
    </div>

    <a href={`/en`}
    class='px-8 py-4 mt-8 font-bold text-black bg-white rounded-full transition-all duration-300 hover:bg-white/90 hover:-translate-y-1' > Back to Home </a>
  </main>
</Layout>

<style>
  .transition-all {
    transition-property: all;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 500ms;
  }
</style>
